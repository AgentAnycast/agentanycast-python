# Test runner image for Docker Compose integration tests.
FROM python:3.12-slim

WORKDIR /app

# Install the SDK with dev dependencies.
COPY pyproject.toml README.md ./
COPY src/ src/
COPY tests/ tests/
COPY conftest.py ./

RUN pip install --no-cache-dir -e ".[dev]"

# Default: run integration tests.
CMD ["pytest", "tests/integration/", "-m", "integration", "-v", "--tb=short"]
